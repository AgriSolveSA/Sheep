# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=https://shepherdai.co.za

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./db/farm.db

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_64_random_chars

# ─── PayFast ──────────────────────────────────────────────────────────────────
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
# Set PAYFAST_SANDBOX=false in production

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="ShepherdAI <noreply@shepherdai.co.za>"

# ─── Paths ────────────────────────────────────────────────────────────────────
PDF_DIR=./reports
BACKUP_DIR=./backups
LOG_DIR=./logs
